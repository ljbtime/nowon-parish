rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // 갤러리 이미지 - 누구나 읽기, 관리자만 업로드
    match /gallery/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.admin == true;
    }

    // 주보 PDF - 누구나 읽기, 관리자만 업로드
    match /bulletin/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.admin == true;
    }
  }
}
