rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 공지사항 - 누구나 읽기, 관리자만 쓰기
    match /notices/{docId} {
      allow read: if true;
      allow create, update, delete: if request.auth != null && request.auth.token.admin == true;
    }

    // 자유게시판 - 누구나 읽기, 로그인 회원 작성, 본인 또는 관리자만 수정/삭제
    match /posts/{docId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null &&
        (resource.data.authorUid == request.auth.uid || request.auth.token.admin == true);
    }

    // 갤러리 - 누구나 읽기, 관리자만 쓰기
    match /gallery/{docId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.admin == true;
    }

    // 미사 시간 - 누구나 읽기, 관리자만 쓰기
    match /massSchedule/{docId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.admin == true;
    }

    // 회원 정보 - 본인만 읽기/쓰기, 관리자는 전체 읽기
    match /users/{userId} {
      allow read: if request.auth != null &&
                    (request.auth.uid == userId || request.auth.token.admin == true);
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null && request.auth.uid == userId;
      allow delete: if request.auth != null && request.auth.token.admin == true;
      // 아이디 중복확인용 목록 조회 (인증 없이)
      allow list: if true;
    }
  }
}
