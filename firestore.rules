rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 공지사항 - 누구나 읽기 가능, 관리자만 쓰기
    match /notices/{docId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.admin == true;
    }

    // 갤러리 - 누구나 읽기 가능, 관리자만 쓰기
    match /gallery/{docId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.admin == true;
    }

    // 미사 시간 - 누구나 읽기 가능, 관리자만 쓰기
    match /massSchedule/{docId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.admin == true;
    }
  }
}
